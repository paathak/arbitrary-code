<?xml version="1.0" encoding="utf-8"?>
<layout onLaunch="launch_home" onVolumeUp="volume_up" onVolumeDown="volume_down" onResume="play_pause" onPause="pause" color="#0F0F0F">
    <grid>
        
        <row>
            <button text="Sleep" onTap="sleep" color="#3C4043" />
            <button text="Close App" onTap="close_app" color="#3C4043" /> <button icon="power" onTap="shutdown" color="#D93025" />
        </row>
        
        <row>
            <button icon="docnew" onTap="new_tab" color="#202124" />
            <button icon="web" onTap="address" color="#202124" />
            <button icon="docclose" onTap="close_tab" color="#202124" /> </row>
        
        <row>
            <button icon="rwd" onTap="rewind" color="#202124" />
            <button icon="playpause" onTap="play_pause" color="#34A853" />
            <button icon="ff" onTap="forward" color="#202124" />
        </row>        
        
        <row weight="4">
            <touch id="touch" 
                 ondown="down"
                 onup="up" 
                 onhold="hold"
                 ontap="tap"
                 ondoubletap="double"
                 ontouchdelta="delta"
                 text="Touchpad"
                 color="#171717" /> 
        </row>

        <row weight="wrap">
            <button text="L-Click" ontap="left" color="#202124" />
            <button text="R-Click" ontap="right" color="#202124" />
        </row>

        <row>
            <button icon="vdown" onTap="volume_down" color="#202124" />
            <button icon="vmute" onTap="volume_mute" color="#202124" />
            <button text="vup" onTap="volume_up" color="#202124" />
        </row>

        <row>
            <button icon="up" onTap="scroll_up" color="#202124" />
            <button icon="home" onTap="launch_home" color="#1A73E8" />
            <button text="pgup" onTap="pg_up" color="#202124" />
        </row>
        
        <row>
            <button icon="down" onTap="scroll_down" color="#202124" />
            <button icon="left" onTap="back" color="#202124" />
            <button text="pgdn" onTap="pg_down" color="#202124" />
        </row>
        
        <row>
            <button icon="fullscreen" onTap="fullscreen" color="#202124" />
            <button icon="right" onTap="forward" color="#202124" />
            <button text="esc" onTap="window" color="#202124" />
        </row>

    </grid>
</layout>
